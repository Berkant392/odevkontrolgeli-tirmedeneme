# ==========================================
# GITHUB'A YÜKLENMEMESİ GEREKENLER LİSTESİ
# ==========================================

# 1. Bağımlılıklar (Sistemde yüzlerce MB yer kaplar, her PC kendi indirir)
node_modules/
/node_modules
.pnp
.pnp.js

# 2. Üretim (Build) Klasörleri (Vite build edince oluşur)
dist/
dist-ssr/
build/
.output/

# 3. Çevre Değişkenleri (Şifreler ve Tokenlar - EN KRİTİĞİ)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# 4. Netlify ve Geçici Sunucu Dosyaları
.netlify/
deno.lock

# 5. Log Dosyaları (Çökme veya debug raporları)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 6. İşletim Sistemi Kalıntıları (Mac/Windows gizli dosyaları)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# 7. Geçici Geliştirici Klasörleri (Karalamalar)
scratch/
coverage/
.nyc_output/
.eslintcache
.stylelintcache

# 8. Editör (IDE) Ayarları
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
